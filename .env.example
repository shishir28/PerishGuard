POSTGRES_DB=perishguard
POSTGRES_USER=perishguard
POSTGRES_PASSWORD=PerishGuard!2026

# By default compose disables the IoT Event Hub trigger so the HTTP dashboard
# query function can run locally without real IoT Hub credentials.
DISABLE_IOT_TRIGGER=true
IOT_HUB_CONNECTION=
IOT_HUB_EVENT_HUB_NAME=telemetry
IOT_HUB_CONSUMER_GROUP=$$Default

# Optional local LLM endpoints. Leave blank to use deterministic fallbacks.
OLLAMA_ENDPOINT=
OLLAMA_MODEL=llama3.3:70b
NEMOCLAW_ENDPOINT=
ALERT_COOLDOWN_MINUTES=30

# Optional real alert delivery channels.
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_EMAIL_SUBJECT_PREFIX=[PerishGuard]
